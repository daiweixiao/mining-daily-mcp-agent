# OpenAI-compatible LLM provider
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash
OPENAI_API_KEY=sk-dd5c65a2671047******
LLM_ENABLED=true

LLM_MAX_TOKENS=1800
